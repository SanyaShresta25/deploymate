# Backend auth
DEPLOYMATE_USERNAME=admin
DEPLOYMATE_PASSWORD=admin123
DEPLOYMATE_API_TOKEN=dev-token-change-me

# SQLite path (optional)
# DEPLOYMATE_DB_PATH=C:\Users\user\Desktop\devops-dashboard\backend\deploymate.db

# GitHub Actions deploy trigger
DEPLOYMATE_GH_TOKEN=ghp_replace_with_real_token
DEPLOYMATE_GH_REPO=your-org/your-repo
DEPLOYMATE_GH_WORKFLOW=deploy.yml
DEPLOYMATE_GH_REF=main

# CORS allowlist (comma-separated). Use * for all origins.
DEPLOYMATE_ALLOWED_ORIGINS=https://deploymate-ashen.vercel.app,http://localhost:3000
